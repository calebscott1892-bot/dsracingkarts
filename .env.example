# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Square (Sandbox first, then swap to production)
NEXT_PUBLIC_SQUARE_APP_ID=sandbox-sq0idb-xxxx
SQUARE_ACCESS_TOKEN=your-square-access-token
NEXT_PUBLIC_SQUARE_LOCATION_ID=your-location-id
SQUARE_ENVIRONMENT=sandbox

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mailchimp
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_LIST_ID=your-list-id

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_PROPERTY_ID=123456789
GA4_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GA4_OAUTH_CLIENT_ID=your-google-oauth-client-id
GA4_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GA4_OAUTH_REFRESH_TOKEN=your-google-oauth-refresh-token

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token
